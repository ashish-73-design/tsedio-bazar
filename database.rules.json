{
  "rules": {
    "products": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },
    "categories": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },
    "orders": {
      ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
      ".indexOn": ["status", "customerPhone", "createdAt"],
      "$orderId": {
        ".read": true,
        ".write": true
      }
    },
    "admins": {
      ".read": "auth != null",
      ".write": false
    }
  }
}
